 572:ili9341/Src/ILI9341_GFX.c **** void ILI9341_Random_line(int16_t x1, int16_t y1, int16_t x2, int16_t y2, uint16_t color)
 573:ili9341/Src/ILI9341_GFX.c **** {
 574:ili9341/Src/ILI9341_GFX.c **** 	// Bresenham's algorithm - thx wikpedia
 575:ili9341/Src/ILI9341_GFX.c **** 
 576:ili9341/Src/ILI9341_GFX.c **** 	int16_t steep = abs(y2 - y1) > abs(x2 - x1);
 577:ili9341/Src/ILI9341_GFX.c **** 
 578:ili9341/Src/ILI9341_GFX.c **** 	if(steep)
 579:ili9341/Src/ILI9341_GFX.c **** 	{
 580:ili9341/Src/ILI9341_GFX.c **** 		swap(x1, y1);
 581:ili9341/Src/ILI9341_GFX.c **** 		swap(x2, y2);
 582:ili9341/Src/ILI9341_GFX.c **** 	}
 583:ili9341/Src/ILI9341_GFX.c **** 
 584:ili9341/Src/ILI9341_GFX.c **** 	if(x1 > x2)
 585:ili9341/Src/ILI9341_GFX.c **** 	{
 586:ili9341/Src/ILI9341_GFX.c **** 		swap(x1, x2);
 587:ili9341/Src/ILI9341_GFX.c **** 		swap(y1, y2);
 588:ili9341/Src/ILI9341_GFX.c **** 	}
 589:ili9341/Src/ILI9341_GFX.c **** 
 590:ili9341/Src/ILI9341_GFX.c **** 	int16_t dx, dy;
 591:ili9341/Src/ILI9341_GFX.c **** 
 592:ili9341/Src/ILI9341_GFX.c **** 	dx = x2 - x1;
 593:ili9341/Src/ILI9341_GFX.c **** 	dy = abs(y2 - y1);
 594:ili9341/Src/ILI9341_GFX.c **** 
 595:ili9341/Src/ILI9341_GFX.c **** 	int16_t err = dx / 2;
 596:ili9341/Src/ILI9341_GFX.c **** 	int16_t ystep;
 597:ili9341/Src/ILI9341_GFX.c **** 
 598:ili9341/Src/ILI9341_GFX.c **** 	if(y1 < y2)
 599:ili9341/Src/ILI9341_GFX.c **** 	{
 600:ili9341/Src/ILI9341_GFX.c **** 		ystep = 1;
 601:ili9341/Src/ILI9341_GFX.c **** 	}
 602:ili9341/Src/ILI9341_GFX.c **** 	else
 603:ili9341/Src/ILI9341_GFX.c **** 	{
ARM GAS  /tmp/ccK067aw.s 			page 17


 604:ili9341/Src/ILI9341_GFX.c **** 		ystep = -1;
 605:ili9341/Src/ILI9341_GFX.c **** 	}
 606:ili9341/Src/ILI9341_GFX.c **** 
 607:ili9341/Src/ILI9341_GFX.c **** 	for(; x1 <= x2; x1++)
 608:ili9341/Src/ILI9341_GFX.c **** 	{
 609:ili9341/Src/ILI9341_GFX.c **** 		if(steep)
 610:ili9341/Src/ILI9341_GFX.c **** 		{
 611:ili9341/Src/ILI9341_GFX.c **** 			ILI9341_Draw_Pixel(y1, x1, color);
 612:ili9341/Src/ILI9341_GFX.c **** 		}
 613:ili9341/Src/ILI9341_GFX.c **** 		else
 614:ili9341/Src/ILI9341_GFX.c **** 		{
 615:ili9341/Src/ILI9341_GFX.c **** 			ILI9341_Draw_Pixel(x1, y1, color);
 616:ili9341/Src/ILI9341_GFX.c **** 		}
 617:ili9341/Src/ILI9341_GFX.c **** 
 618:ili9341/Src/ILI9341_GFX.c **** 		err -= dy;
 619:ili9341/Src/ILI9341_GFX.c **** 
 620:ili9341/Src/ILI9341_GFX.c **** 		if(err < 0)
 621:ili9341/Src/ILI9341_GFX.c **** 		{
 622:ili9341/Src/ILI9341_GFX.c **** 			y1 += ystep;
