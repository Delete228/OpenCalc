 265:ili9341/Src/ILI9341_GFX.c **** //INTERNAL FUNCTION OF LIBRARY
 266:ili9341/Src/ILI9341_GFX.c **** /*Sends block colour information to LCD*/
 267:ili9341/Src/ILI9341_GFX.c **** void ILI9341_Draw_Colour_Burst(uint16_t Colour, uint32_t Size)
 268:ili9341/Src/ILI9341_GFX.c **** {
 269:ili9341/Src/ILI9341_GFX.c **** 	DISP_DC_DATA;
 270:ili9341/Src/ILI9341_GFX.c **** 	DISP_CS_SELECT;
 271:ili9341/Src/ILI9341_GFX.c **** 
 272:ili9341/Src/ILI9341_GFX.c **** 	while(Size > 0)
 273:ili9341/Src/ILI9341_GFX.c **** 	{
 274:ili9341/Src/ILI9341_GFX.c **** 		DISP_SPI->DR = (Colour >> 8);
 275:ili9341/Src/ILI9341_GFX.c **** 		while(!(DISP_SPI->SR & SPI_SR_TXE));
 276:ili9341/Src/ILI9341_GFX.c **** 		DISP_SPI->DR = Colour;
 277:ili9341/Src/ILI9341_GFX.c **** 		while(!(DISP_SPI->SR & SPI_SR_TXE));
 278:ili9341/Src/ILI9341_GFX.c **** 		Size--;
 279:ili9341/Src/ILI9341_GFX.c **** 	}
 280:ili9341/Src/ILI9341_GFX.c **** 
 281:ili9341/Src/ILI9341_GFX.c **** 	while(!(DISP_SPI->SR & SPI_SR_TXE));
 282:ili9341/Src/ILI9341_GFX.c **** 	while(DISP_SPI->SR & SPI_SR_BSY);
 283:ili9341/Src/ILI9341_GFX.c **** 	DISP_CS_UNSELECT;
 284:ili9341/Src/ILI9341_GFX.c **** }
